{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/evaluate", "destination": "/api/evaluate" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
